# =============================================================================
# home-agent — copy to .env and adjust (never commit real .env)
# Full guide: docs/configuration.md
# =============================================================================

# --- Required for vault / note / queue / heartbeat -----------------------------
# Absolute path to your Obsidian (markdown) vault directory.
HOMEAGENT_VAULT=/path/to/your/vault
# Alternative name (checked if HOMEAGENT_VAULT unset):
# OBSIDIAN_VAULT=/path/to/your/vault

# --- LLM: pick ONE style (OpenAI cloud OR Ollama local) ----------------------
# If OPENAI_API_KEY is set → OpenAI-compatible API (default https://api.openai.com/v1).
# Set OPENCLAWD_MODEL to an id your endpoint actually serves (404 = wrong model or wrong base URL).
# OPENAI_BASE_URL=   # Azure, Groq, LiteLLM, etc. (OpenAI-compatible /v1)
# OPENAI_API_KEY=sk-...
# OPENCLAWD_MODEL=gpt-4o-mini
#
# If OPENAI_API_KEY is unset → Ollama. OLLAMA_MODEL = pulled tag (ollama list), not GPT-* unless you have it.
OPENCLAWD_OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Optional: heartbeat-only model (else same as OLLAMA_MODEL / OPENCLAWD_MODEL)
# HEARTBEAT_MODEL=

# --- SQLite stores (defaults are fine for most setups) ------------------------
# Job queue; default is {HOMEAGENT_VAULT}/.heartbeat/queue.db
# HOMEAGENT_QUEUE_DB=

# Agent memory (BM25); default under project data/
# HOMEAGENT_MEMORY_DB=

# --- Coordinator + heartbeat queue depth --------------------------------------
# Background poll in main.py: spawn heartbeat when pending queue >= threshold
# HOMEAGENT_ENABLE_COORDINATOR=false
HOMEAGENT_HEARTBEAT_QUEUE_THRESHOLD=5

# Stub heartbeat plans (no LLM API calls)
# HOMEAGENT_HEARTBEAT_NO_LLM=0
#
# POST /heartbeat/test from browser UI (server.py). Set 0 on shared servers.
# Also gates GET /heartbeat/workflow and GET /queue/* (stats, items).
# HOMEAGENT_ENABLE_HEARTBEAT_TEST_API=1

# Poll SQLite for queue rows with metadata.notify_session_id → push queue_task on WS (server.py)
# HOMEAGENT_ENABLE_QUEUE_WS_NOTIFY=1
# HOMEAGENT_QUEUE_WS_POLL_SEC=5

# --- Conversational agent safety ----------------------------------------------
# Allow note new|write|tag|mv from chat/voice (default: blocked in conversation role)
# HOMEAGENT_ALLOW_CHAT_VAULT_WRITE=0

# --- crontab via run() (off by default; hardened) -----------------------------
# Master switch. Chat still blocked unless HOMEAGENT_ALLOW_CRONTAB_CONVERSATION=1
# (reduces prompt-injection risk from user messages).
# HOMEAGENT_ALLOW_CRONTAB=0
# HOMEAGENT_ALLOW_CRONTAB_CONVERSATION=0
# Optional: comma-separated substrings each job line must contain (default: heartbeat,home_agent,home-agent)
# HOMEAGENT_CRONTAB_JOB_MARKERS=heartbeat,home_agent
# Max staging file size in bytes (default 24576). Install only from:
#   $HOMEAGENT_VAULT/.heartbeat/crontab_staging/<file>
# HOMEAGENT_CRONTAB_MAX_BYTES=24576

# --- Semantic search (note find) ----------------------------------------------
# OPENAI_API_KEY required for live embeddings unless you use test fixtures
HOMEAGENT_EMBED_MODEL=text-embedding-3-small
# HOMEAGENT_TEST_EMBED_JSON=/path/to/embeddings.json

# --- Skills / workspace (usually auto-set by server) ---------------------------
# OPENCLAWD_SKILLS_ROOT=
# OPENCLAWD_PERSISTENT_ROOT=
